{
  "name": "@fitnessfight/infrastructure",
  "version": "1.0.0",
  "private": true,
  "description": "AWS CDK infrastructure for fitnessfight.club",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest --passWithNoTests",
    "cdk": "cdk",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "deploy:dev": "cdk deploy fitnessfight-club-dev-Stack --require-approval never",
    "deploy:prod": "cdk deploy fitnessfight-club-prod-Stack --require-approval never",
    "synth": "cdk synth"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.211.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "aws-cdk": "^2.1029.3",
    "esbuild": "^0.25.9",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2"
  }
}
