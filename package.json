{
  "name": "fitnessfight.club",
  "version": "1.0.0",
  "private": true,
  "description": "Fitness tracking website tied to Strava club",
  "workspaces": [
    "frontend",
    "infrastructure"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test --workspaces --if-present -- --watch",
    "test:coverage": "npm run test --workspaces --if-present -- --coverage",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint --workspaces --if-present -- --fix",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,md,yml,yaml,css}'",
    "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,json,md,yml,yaml,css}'",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "quality": "npm run lint && npm run typecheck && npm run test",
    "quality:fix": "npm run lint:fix && npm run format",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "husky": "^8.0.3",
    "lint-staged": "^16.1.5",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/fitnessfight.club.git"
  },
  "author": "",
  "license": "UNLICENSED"
}
